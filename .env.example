# OpenEMR instance the dashboard talks to.
OPENEMR_BASE_URL=https://localhost:9300
OPENEMR_SITE=default

# OAuth2 confidential client. Generated by `pnpm tsx scripts/register-client.ts`
# (Phase 1) or registered manually via OpenEMR Admin → System → API Clients.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/callback

# 32+ byte random string for iron-session encryption.
# Generate: `openssl rand -base64 48`
SESSION_SECRET=

# Public app URL (used for absolute redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Test patient for local dev.
# TEST_PATIENT_ID  = the FHIR Patient.id (used by /patient/[id] routes)
# TEST_PATIENT_PID = OpenEMR's internal numeric pid (used by the Phase 6 PHP
#                    bridge link, which passes pid in the URL)
TEST_PATIENT_ID=
TEST_PATIENT_PID=

# LOCAL DEV ONLY: OpenEMR dev instances typically use a self-signed TLS cert
# on https://localhost:9300. Setting this to "0" lets server-side fetch
# accept it. NEVER set this in any non-local environment.
# NODE_TLS_REJECT_UNAUTHORIZED=0
